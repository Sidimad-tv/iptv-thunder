{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "S!d!m@dtv-STB",
  "version": "1.0.0",
  "identifier": "com.sidimadtv.stb",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' data: blob: http: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: http: https: 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' data: blob: http: https:; img-src 'self' data: http: https: asset: http://asset.localhost; connect-src 'self' http: https: ws: wss: ipc: http://ipc.localhost data: blob:; font-src 'self' data: http: https:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-src 'self' http: https: data: blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "requireLiteralLeadingDot": false
        }
      },
      "capabilities": ["desktop", "mobile"]
    },
    "windows": [
      {
        "label": "main",
        "title": "S!d!m@dtv-STB",
        "width": 1200,
        "height": 720,
        "minWidth": 900,
        "minHeight": 560,
        "visible": true,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "lib/**/*",
      "../exec/update.exe"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://api.github.com/repos/Sidimad-tv/iptv-thunder/releases/latest"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
